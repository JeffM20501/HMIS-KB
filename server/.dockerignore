# Ignore version control systems
.git
.gitignore

# Ignore local dependency folders
node_modules/
vendor/

# Ignore environment variables and secrets
.env
.env.*
*.pem
*.key

.venv
venv

# Ignore IDE and editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj

# Ignore OS-generated files
.DS_Store
Thumbs.db

# Ignore test coverage and log directories
coverage/
*.log
npm-debug.log*

# Ignore build artifacts
dist/
build/
out/

__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.env
.pytest_cache/

# Ignore all markdown files
*.md

# Exception: Do not ignore README.md
!README.md

db.sqlite3
*.sqlite3

Dockerfile
.dockerignore 